{
  "name": "@foxhound-ai/sdk",
  "version": "0.1.0",
  "description": "Compliance-grade observability SDK for AI agents — trace, replay, and audit every agent decision",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/caleb-love/foxhound.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "ai",
    "agents",
    "observability",
    "tracing",
    "opentelemetry",
    "llm",
    "audit"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./integrations/claude-agent": {
      "import": "./dist/integrations/claude-agent.js",
      "types": "./dist/integrations/claude-agent.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@foxhound/types": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
