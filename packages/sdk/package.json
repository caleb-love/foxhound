{
  "name": "@foxhound-ai/sdk",
  "version": "0.2.1",
  "description": "Observability SDK for AI agents — trace, replay, and audit every agent decision",
  "license": "MIT",
  "type": "module",
  "homepage": "https://foxhound.caleb-love.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/caleb-love/foxhound.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/caleb-love/foxhound/issues",
    "email": "foxhound@caleb-love.com"
  },
  "keywords": [
    "ai",
    "agents",
    "observability",
    "tracing",
    "opentelemetry",
    "llm",
    "audit"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./integrations/claude-agent": {
      "import": "./dist/integrations/claude-agent.js",
      "types": "./dist/integrations/claude-agent.d.ts"
    },
    "./integrations/opentelemetry": {
      "import": "./dist/integrations/opentelemetry.js",
      "types": "./dist/integrations/opentelemetry.d.ts"
    }
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.4.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@foxhound/types": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
