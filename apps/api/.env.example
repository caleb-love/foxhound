PORT=3001
HOST=0.0.0.0
DATABASE_URL=postgresql://foxhound:foxhound@localhost:5432/foxhound_dev
JWT_SECRET=change-me-in-production
LOG_LEVEL=info

# Stripe billing (required for billing features)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_ANNUAL=price_...
STRIPE_PRICE_ID_TEAM_MONTHLY=price_...
STRIPE_PRICE_ID_TEAM_ANNUAL=price_...

# Internal cron secret (required for metering cron endpoint)
INTERNAL_CRON_SECRET=change-me-in-production

# Web dashboard URL (used for SSO redirects)
FRONTEND_URL=http://localhost:3000

# Cloud deployment
FOXHOUND_CLOUD=
# Neon Postgres (used in cloud — overrides DATABASE_URL)
# DATABASE_URL=postgresql://...@ep-xxx.us-east-2.aws.neon.tech/foxhound?sslmode=require
# Upstash Redis (optional — for distributed rate limiting)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
